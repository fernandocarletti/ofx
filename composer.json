{
  "name": "fernandocarletti/ofx",
  "description": "Object-oriented PHP parser for Open Financial Exchange (OFX) files supporting OFX v1 (SGML) and v2 (XML)",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "ofx",
    "parser",
    "banking",
    "finance",
    "investment",
    "qfx",
    "financial"
  ],
  "authors": [
    {
      "name": "Fernando Carletti",
      "email": "fernando@carletti.dev"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-simplexml": "*",
    "ext-libxml": "*",
    "ext-bcmath": "*",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.93",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Ofx\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ofx\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix"
  },
  "config": {
    "sort-packages": true
  }
}
